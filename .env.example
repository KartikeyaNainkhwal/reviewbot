# ─── GitHub App ──────────────────────────────────────────────────────────
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=whsec_your_webhook_secret_here
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx

# ─── Anthropic ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TIMEOUT_MS=120000

# ─── Database ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://axd:axd_dev@localhost:5432/axd?schema=public

# ─── Redis ───────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Server ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# ─── Queue Configuration ────────────────────────────────────────────────
QUEUE_CONCURRENCY=3
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_DELAY_MS=5000

# ─── Rate Limits & Guardrails ───────────────────────────────────────────
MAX_FILES_PER_REVIEW=20
MAX_DIFF_SIZE_BYTES=500000
MAX_REVIEWS_PER_HOUR_PER_INSTALL=30

# ─── Optional: Monitoring ───────────────────────────────────────────────
# SENTRY_DSN=https://xxxx@sentry.io/xxxx
